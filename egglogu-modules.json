  "coupling_points": [
    {
      "id": "CP-001",
      "severity": "high",
      "description": "saveIncome writes to inventory via production cross-reference",
      "from_module": "finances",
      "to_module": "inventory",
      "mitigation": "Use event bus pattern instead of direct access"
    },
    {
      "id": "CP-002",
      "severity": "high",
      "description": "deleteClient cascades to finances (receivables) and traceability",
      "from_module": "clients",
      "to_module": "finances",
      "mitigation": "Cascade deletes should go through data layer, not direct module access"
    },
    {
      "id": "CP-003",
      "severity": "high",
      "description": "qeSaveEggs in quick_entry writes to production and inventory data",
      "from_module": "rbac_kpi",
      "to_module": "production",
      "mitigation": "Quick entry should call production module's save function"
    },
    {
      "id": "CP-004",
      "severity": "medium",
      "description": "WorkflowEngine.evaluate(DATA) called by saveData() — crosses workflow boundary",
      "from_module": "data",
      "to_module": "workflows",
      "mitigation": "Event-driven: saveData emits event, WorkflowEngine listens"
    },
    {
      "id": "CP-005",
      "severity": "medium",
      "description": "VENG.census(D) reaches into all modules for validation",
      "from_module": "veng",
      "to_module": "*",
      "mitigation": "Each module exposes its own validation, VENG aggregates results"
    },
    {
      "id": "CP-006",
      "severity": "medium",
      "description": "computeFlockHealthScore crosses health + flocks + production modules",
      "from_module": "traceability",
      "to_module": "health",
      "mitigation": "Health module should expose computeFlockHealthScore as API"
    }
  ],
  "rules": {
    "lock_enforcement": "Pre-commit hook blocks any commit modifying lines within a locked module",
    "unlock_procedure": "Only the owner (Jose Antonio del Solar) can unlock via hardlock-erp.sh unlock <module>",
    "cross_module_access": "Modules may only access other modules through the shared DATA object and shared utility functions. Direct function calls across feature modules are PROHIBITED.",
    "new_module_policy": "New modules must be registered in this manifest before code is written",
    "checksum_storage": ".egglogu-hardlock.json stores per-module SHA256 checksums"
  }
}
