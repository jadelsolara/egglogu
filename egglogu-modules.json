    "egglogu.html": {
      "description": "App shell — HTML structure, CSS, section containers",
      "lockable": true,
      "protected_zones": [
        {"name": "login-screen", "description": "Login UI — NEVER modify"},
        {"name": "sidebar-logo", "description": "Sidebar logo — NEVER modify"},
        {"name": "nav-login-btn", "description": "Acceso Clientes button — NEVER modify"},
        {"name": "lang-picker-fixed", "description": "Language globe — position:fixed, NEVER move"}
      ]
    },
